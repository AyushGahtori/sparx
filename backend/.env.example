APP_NAME=SPARX AI Agent Calling Module
ENVIRONMENT=local
APP_PORT=8000
API_V1_PREFIX=/api
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=false
REQUEST_TIMEOUT_SECONDS=10
CORS_ORIGINS=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5501,http://localhost:5501,http://127.0.0.1:8000,http://localhost:8000
PUBLIC_BASE_URL=
AUTO_PUBLIC_TUNNEL_ENABLED=true
CLOUDFLARED_PATH=tools/cloudflared.exe
CLOUDFLARED_PROTOCOL=http2
PUBLIC_TUNNEL_START_TIMEOUT_SECONDS=25
PUBLIC_TUNNEL_HEALTH_TIMEOUT_SECONDS=6
AGENTS_CONFIG_PATH=app/config/agents.json
RATE_LIMIT_ENABLED=true
GENERAL_RATE_LIMIT_PER_MINUTE=100
CALL_RATE_LIMIT_PER_MINUTE=10
CAMPAIGN_START_RATE_LIMIT_PER_MINUTE=5
TWILIO_WEBHOOK_VALIDATION_ENABLED=true
TWILIO_WEBHOOK_REPLAY_WINDOW_SECONDS=300
QUEUE_RECOVERY_STALE_SECONDS=300
DUPLICATE_MANUAL_CALL_WINDOW_MINUTES=10
CAMPAIGN_CSV_MAX_FILE_SIZE_BYTES=2097152
CAMPAIGN_CSV_MAX_ROWS=2000
CAMPAIGN_MAX_PARALLEL_CALLS=3
CAMPAIGN_DISPATCH_INTERVAL_SECONDS=30
CALLBACK_DEFAULT_TIMEZONE=Asia/Kolkata
CALLBACK_BUSINESS_HOUR_START=9
CALLBACK_BUSINESS_HOUR_END=19
CALLBACK_MAX_PARALLEL_CALLS=2
CALLBACK_DISPATCH_INTERVAL_SECONDS=60
CALLBACK_DUPLICATE_WINDOW_MINUTES=60
CALL_MAX_AUTO_CALLS=3
CALL_RETRY_INTERVAL_MINUTES=10
GEMMA_MODEL_NAME=gemma-4-26b-a4b-it
GEMMA_REQUEST_TIMEOUT_SECONDS=40
GEMMA_MAX_RETRIES=2
AI_MAX_PARALLEL_JOBS=1
AI_DISPATCH_INTERVAL_SECONDS=60
RUNNER_QUERY_LIMIT=50
DASHBOARD_LIST_LIMIT=100
FIRESTORE_OPERATION_TIMEOUT_SECONDS=3
MONGODB_FALLBACK_ENABLED=false
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=sparx
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_OAUTH_CLIENT_SECRETS_PATH=google-oauth-client-secrets.json
GOOGLE_OAUTH_TOKEN_PATH=google-calendar-token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_MEET_EVENT_DURATION_MINUTES=30

FIREBASE_CREDENTIALS_PATH=
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=YOUR_FIREBASE_PRIVATE_KEY_WITH_ESCAPED_NEWLINES
FIREBASE_CLIENT_EMAIL=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

DEEPGRAM_API_KEY=
DEEPGRAM_PROJECT_ID=

GEMMA_API_KEY=
